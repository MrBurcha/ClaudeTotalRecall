{
  "name": "claude-total-recall",
  "version": "0.11.1",
  "description": "Claude Total Recall — sync Claude Code memory across machines via a private GitHub repo",
  "author": "MrBurcha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrBurcha/ClaudeTotalRecall.git"
  },
  "homepage": "https://github.com/MrBurcha/ClaudeTotalRecall#readme",
  "bugs": {
    "url": "https://github.com/MrBurcha/ClaudeTotalRecall/issues"
  },
  "main": "./out/main/main.js",
  "bin": {
    "claude-total-recall": "./dist-cli/index.js"
  },
  "scripts": {
    "postinstall": "patch-package",
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "electron-vite dev",
    "build:app": "electron-vite build",
    "preview": "electron-vite preview",
    "build:cli": "tsup",
    "cli:check": "npm run build:cli && node dist-cli/index.js check",
    "icon": "bash scripts/make-icon.sh",
    "icons": "bash scripts/make-icons.sh",
    "background": "bash scripts/make-background.sh",
    "build:mac": "npm run build:app && electron-builder --mac --config electron-builder.yml",
    "build:linux": "npm run build:app && electron-builder --linux --config electron-builder.yml",
    "build:win": "npm run build:app && electron-builder --win --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "i18next": "^26.3.6",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.1",
    "electron-builder": "^26",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron@43.1.1": true,
    "esbuild@0.28.1": true
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
